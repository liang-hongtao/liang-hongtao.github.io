---
layout: default
---

<div class="row academic-home">
  {% if page.profile %}
    <div class="col-sm-3">
      <nav id="sidebar" class="sticky-top academic-sidebar">
        <div class="sidebar-content">
          {% if page.profile.image %}
            <div class="text-center mb-4">
              {% assign profile_image_path = page.profile.image | prepend: 'assets/img/' %}
              {% if page.profile.image_circular %}
                {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle profile-sidebar-image' %}
              {% else %}
                {% assign profile_image_class = 'img-fluid z-depth-1 rounded profile-sidebar-image' %}
              {% endif %}
              {% include figure.liquid loading="eager" path=profile_image_path class=profile_image_class sizes="200px" alt=page.profile.image cache_bust=true %}
            </div>
          {% endif %}

          <div class="text-center mb-4">
            <h2 class="font-weight-bold sidebar-name">
              {% if page.profile.display_name %}
                {{ page.profile.display_name }}
              {% else %}
                {{ site.first_name }}
                {% if site.middle_name %}{{ site.middle_name }}{% endif %}
                {{ site.last_name }}
              {% endif %}
            </h2>
            {% if page.profile.role %}
              <p class="text-muted sidebar-title">{{ page.profile.role }}</p>
            {% elsif page.subtitle %}
              <p class="text-muted sidebar-title">{{ page.subtitle | strip_html }}</p>
            {% endif %}
          </div>

          {% if page.profile.links %}
            <div class="sidebar-links" aria-label="profile links">
              {% for item in page.profile.links %}
                <div class="sidebar-link-item">
                  <span class="sidebar-link-icon" aria-hidden="true">
                    <i class="{{ item.icon }}"></i>
                  </span>
                  {% if item.url %}
                    {% assign item_url_prefix = item.url | slice: 0, 4 %}
                    {% if item_url_prefix == 'http' or item.url contains 'mailto:' %}
                      <a class="sidebar-link-label {% if item.label == 'ResearchGate' %}researchgate-link{% endif %}" href="{{ item.url }}" {% if item_url_prefix == 'http' %}target="_blank" rel="external nofollow noopener"{% endif %}>
                        {{ item.label }}
                      </a>
                    {% else %}
                      <a class="sidebar-link-label" href="{{ item.url | relative_url }}">{{ item.label }}</a>
                    {% endif %}
                  {% else %}
                    <span class="sidebar-link-label">{{ item.label }}</span>
                  {% endif %}
                </div>
              {% endfor %}
            </div>
          {% elsif page.profile.more_info %}
            <div class="sidebar-more-info">{{ page.profile.more_info }}</div>
          {% endif %}

          {% if page.social %}
            <div class="sidebar-social">
              <div class="contact-icons">{% social_links %}</div>
            </div>
          {% endif %}
        </div>
      </nav>
    </div>
  {% endif %}

  <div class="{% if page.profile %}col-sm-9{% else %}col-sm-12{% endif %}">
    <div class="post">
      <header class="post-header">
        <h1 class="post-title">
          {% if site.title == 'blank' %}
            <span class="font-weight-bold">{{ site.first_name }}</span>
            {% if site.middle_name %}{{ site.middle_name }}{% endif %}
            {{ site.last_name }}
          {% else %}
            {{ site.title }}
          {% endif %}
        </h1>
        <p class="desc">{{ page.subtitle }}</p>
      </header>

      <article>
        <div class="clearfix">{{ content }}</div>

        {% if page.announcements and page.announcements.enabled %}
          <h2>
            <a href="{{ '/news/' | relative_url }}" style="color: inherit">{{ site.data[site.active_lang].strings.news }}</a>
          </h2>
          {% include news.liquid limit=true %}
        {% endif %}

        {% if page.latest_posts and page.latest_posts.enabled %}
          <h2>
            <a href="{{ '/blog/' | relative_url }}" style="color: inherit">{{ site.data[site.active_lang].strings.latest_posts }}</a>
          </h2>
          {% include latest_posts.liquid %}
        {% endif %}

        {% if page.selected_papers %}
          <h2>
            <a href="{{ '/publications/' | relative_url }}" style="color: inherit">{{ site.data[site.active_lang].strings.selected_publications }}</a>
          </h2>
          {% include selected_papers.liquid %}
        {% endif %}
      </article>
    </div>
  </div>
</div>
