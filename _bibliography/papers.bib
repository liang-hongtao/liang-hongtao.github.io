@article{zhang2026spectrumlidar,
  abbr={ZTE Tech},
  bibtex_show={true},
  title={Embodied Mapping and Navigation via Joint Spectrum and {LiDAR} Sensing in Unknown Environments},
  title_zh={面向未知环境的频谱与激光雷达联合具身建图与导航},
  author={Zhang, Jiayi and Liang, Hongtao and Wan, Yiyao and Zhou, Fuhui and Wu, Qihui},
  journal={ZTE Communications Technology},
  journal_zh={中兴通讯技术},
  month={apr},
  year={2026},
  note={Accepted; information made available online on April 30, 2026. Publication details pending.},
  note_zh={已录用；相关信息于2026年4月30日在线公开，待刊。},
  abstract={A joint spectrum-and-LiDAR embodied mapping and navigation framework is developed for unknown environments. It fuses sparse spectrum samples with local geometric information to reconstruct a global radio-signal potential field and obstacle probability map, and employs deep reinforcement learning for history-aware action optimization. In a 40-by-40 indoor grid environment, the method reaches an 82 percent navigation success rate after 5,000 training episodes while reducing collisions and path redundancy relative to baseline methods. Generalization tests across map scales and outdoor low-altitude parameter settings demonstrate robust scene adaptability.},
  abstract_zh={提出了一种频谱与激光雷达联合具身建图与导航的框架。该框架以多通道栅格张量表征环境状态，在感知层通过建图网络将稀疏频谱采样与局部几何信息联合反演为全局频谱信号势场与障碍概率图，实现目标引导与几何约束的有效融合；在决策层引入深度强化学习网络以捕捉历史轨迹与环境特征，并实现动作策略优化。仿真结果表明，在40×40室内栅格环境中经过5,000轮训练后，所提方法的导航成功率达到82%，相较基线方法显著降低了碰撞率与路径冗余度。多种地图尺度及室外低空参数配置下的泛化测试验证了该框架的有效性、鲁棒性与场景适应能力。},
  keywords={UAV indoor navigation, spectrum map construction, reinforcement learning, embodied intelligence},
  selected={false}
}

